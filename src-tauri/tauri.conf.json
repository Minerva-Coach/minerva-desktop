{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minerva Coach",
  "version": "0.1.14",
  "identifier": "com.minervacoach.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "Minerva Coach",
        "width": 280,
        "height": 420,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "",
        "width": 340,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://minervacoach.com https://*.minervacoach.com wss://minervacoach.com wss://*.minervacoach.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": "^(https://([a-z0-9-]+\\.)*minervacoach\\.com(/.*)?|https://127\\.0\\.0\\.1:[0-9]+(/.*)?|mailto:[A-Za-z0-9._%+-]+@minervacoach\\.com)$"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MzVDRDg0OERERDE5NzcKUldSM0dkMk5oTTAxaVVwZEZoUlprZ0NaRFZrUFhsemVVbVkxcVJQcituSDlzZHpJRVo1bFA1SngK",
      "endpoints": [
        "https://github.com/Minerva-Coach/minerva-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
