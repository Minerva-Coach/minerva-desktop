{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-app/refs/heads/main/nicegram-features/nicegram-assistant/nicegram-assistant-js/node_modules/@anthropic-ai/sdk/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Minerva Coach",
  "version": "0.1.3",
  "identifier": "com.minervacoach.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "panel",
        "title": "Minerva Coach",
        "width": 280,
        "height": 420,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "",
        "width": 80,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://minervacoach.com https://*.minervacoach.com https://127.0.0.1:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MzVDRDg0OERERDE5NzcKUldSM0dkMk5oTTAxaVVwZEZoUlprZ0NaRFZrUFhsemVVbVkxcVJQcituSDlzZHpJRVo1bFA1SngK",
      "endpoints": [
        "https://github.com/Minerva-Coach/minerva-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
